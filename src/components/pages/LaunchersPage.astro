---
import CatalogView from "./CatalogView.astro";
import { getToolItems } from "../../lib/catalog";
import { t, type Lang } from "../../i18n";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const items = await getToolItems(lang);
---

<CatalogView
  lang={lang}
  items={items}
  h1={t(lang, "launchers.title")}
  tagline={t(lang, "launchers.intro")}
  countTmpl={t(lang, "count.toolsOf")}
/>
