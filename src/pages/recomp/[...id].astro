---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import ItemDetailPage from "../../components/pages/ItemDetailPage.astro";

export const getStaticPaths = (async () => {
  const recomps = await getCollection("recomps");
  return recomps.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
---

<ItemDetailPage type="recomp" entry={entry} lang="es" />
